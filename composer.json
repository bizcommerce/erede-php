{
  "name": "bizcommerce/erede-php",
  "description": "e.Rede integration SDK",
  "license": "MIT",
  "type": "library",
  "keywords": ["rede", "erede", "payment", "pix", "3ds", "tokenization", "psr-18"],
  "require": {
    "php": ">=8.1",
    "ext-json": "*",
    "psr/log": "^1.1 || ^2.0 || ^3.0",
    "psr/http-client": "^1.0",
    "psr/http-factory": "^1.0",
    "psr/http-message": "^1.1 || ^2.0",
    "php-http/discovery": "^1.19"
  },
  "require-dev": {
    "phpunit/phpunit": "^11",
    "nyholm/psr7": "^1.8",
    "php-http/mock-client": "^1.6",
    "phpstan/phpstan": "^2.2",
    "squizlabs/php_codesniffer": "^3.13 || ^4.0"
  },
  "suggest": {
    "monolog/monolog": "Allows more advanced logging of the application flow",
    "symfony/http-client": "A PSR-18 HTTP client implementation",
    "guzzlehttp/guzzle": "A PSR-18 HTTP client implementation"
  },
  "autoload": {
    "psr-4": {
      "Rede\\": "src/Rede"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Rede\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit",
    "phpstan": "phpstan analyse",
    "cs": "phpcs",
    "cs-fix": "phpcbf",
    "check": [
      "@cs",
      "@phpstan",
      "@test"
    ]
  },
  "config": {
    "allow-plugins": {
      "php-http/discovery": true
    }
  },
  "authors": [
    {
      "name": "João Batista Neto",
      "email": "neto.joaobatista@gmail.com"
    }
  ]
}
